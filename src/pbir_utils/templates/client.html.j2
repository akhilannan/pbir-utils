<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PBIR-Utils UI</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        {% include 'css/wireframe.css' %}

        /* Client UI Additions */
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: var(--card-bg);
        }

        i[data-lucide] {
            width: 14px;
            height: 14px;
            vertical-align: middle;
        }

        [data-theme="dark"] {
            --sidebar-bg: var(--card-bg);
        }

        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-color);
        }

        .app-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            min-width: 150px;
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            overflow: visible;
            position: relative;
            transition: width 0.05s linear;
            box-shadow: var(--shadow-md);
            z-index: 50;
        }

        .sidebar.collapsed {
            width: 0 !important;
            min-width: 0;
            border-right: none;
        }

        .sidebar-resizer {
            position: absolute;
            top: 0;
            right: -3px;
            bottom: 0;
            width: 6px;
            cursor: col-resize;
            z-index: 100;
            background: transparent;
            transition: background 0.2s;
        }

        .sidebar-resizer:hover, .sidebar-resizer.resizing {
            background: var(--accent-color);
            opacity: 0.5;
        }

        .sidebar.collapsed .sidebar-section {
            display: none !important;
        }

        /* Activity Bar */
        .activity-bar {
            width: 48px;
            background: var(--bg-color);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 8px 0;
            z-index: 60;
            flex-shrink: 0;
        }

        .activity-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            cursor: pointer;
            border-radius: 8px;
            margin-bottom: 4px;
            transition: all 0.2s;
            position: relative;
        }

        .activity-icon:hover {
            color: var(--text-primary);
            background: var(--hover-bg);
        }

        .activity-icon.active {
            color: var(--accent-color);
        }

        .activity-icon.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 8px;
            bottom: 8px;
            width: 3px;
            background-color: var(--accent-color);
            border-radius: 0 4px 4px 0;
        }

        .activity-bar .spacer {
            flex: 1;
        }

        .sidebar-section {
            padding: 0;
            display: none; /* Only show active section */
            flex-direction: column;
            overflow: hidden;
            flex: 1; /* Always take full height when visible */
            min-height: 0;
        }

        .sidebar-section.active {
            display: flex;
        }

        .sidebar-section-header {
            padding: 12px 16px;
            margin: 0;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-secondary);
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            user-select: none;
            flex-shrink: 0;
            background: rgba(0,0,0,0.02);
            border-bottom: 1px solid var(--border-color);
        }

        [data-theme="dark"] .sidebar-section-header {
            background: rgba(255,255,255,0.02);
        }

        .sidebar-section-header .section-title {
            flex: 1;
        }

        .sidebar-section-content {
            overflow-y: auto;
            flex: 1;
            padding: 0;
            scrollbar-width: thin;
            scrollbar-gutter: stable;
        }

        /* File Browser styling is now handled directly by the generic .sidebar-section classes */

        .file-item {
            padding: 8px 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            border-radius: 6px;
            margin: 2px 8px;
            transition: all 0.2s;
            color: var(--text-primary);
        }

        .file-item:hover {
            background: var(--hover-bg);
        }

        .file-item.active {
            background: var(--accent-color);
            color: white;
            font-weight: 500;
            box-shadow: var(--shadow-sm);
        }

        .file-item.report {
            font-weight: 500;
        }

        .breadcrumb {
            padding: 8px 16px;
            font-size: 12px;
            color: var(--text-secondary);
            background: transparent;
            display: flex;
            align-items: center;
            gap: 4px;
            flex-wrap: wrap;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 4px;
        }

        .breadcrumb-item {
            cursor: pointer;
            color: var(--accent-color);
            font-weight: 500;
        }

        .breadcrumb-item:hover {
            text-decoration: underline;
        }

        /* Actions Panel */
        .actions-panel .sidebar-section-content {
            overflow-y: auto;
            padding-bottom: 10px;
        }

        .action-item {
            padding: 6px 16px;
            font-size: 13px;
            line-height: 1.4;
            display: flex;
            align-items: flex-start;
            gap: 8px;
            color: var(--text-primary);
        }

        .action-item:hover {
            background: var(--hover-bg);
        }

        .action-item input[type="checkbox"] {
            margin: 0;
            margin-top: 2px; /* Align with first line of text */
            accent-color: var(--accent-color);
        }

        .action-buttons {
            display: flex;
            gap: 8px;
            padding: 12px 16px;
        }

        .action-btn {
            flex: 1;
            padding: 8px 12px;
            font-size: 12px;
            font-weight: 600;
            border: 1px solid transparent;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            height: 32px;
        }

        .action-btn.primary {
            background: var(--accent-color);
            color: white;
            box-shadow: var(--shadow-sm);
        }

        .action-btn.primary:hover:not(:disabled) {
            filter: brightness(1.1);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        .action-btn.secondary {
            background: transparent;
            border-color: var(--border-color);
            color: var(--text-primary);
        }

        .action-btn.secondary:hover:not(:disabled) {
            border-color: var(--accent-color);
            color: var(--accent-color);
            background: rgba(59, 130, 246, 0.05);
        }

        [data-theme="dark"] .action-btn.secondary {
            background: transparent !important;
            color: var(--text-primary) !important;
            border-color: var(--border-color) !important;
        }

        [data-theme="dark"] .action-btn.secondary:hover:not(:disabled) {
            background: rgba(255, 255, 255, 0.05) !important;
            color: var(--text-primary) !important;
            border-color: var(--accent-color) !important;
        }

        .action-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            filter: grayscale(0.5);
            transform: none !important;
            box-shadow: none !important;
        }

        .action-separator {
            padding: 12px 16px 4px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-secondary);
            letter-spacing: 0.5px;
            margin-top: 4px;
            border-top: 1px solid var(--border-color);
        }

        .action-item.additional {
            opacity: 0.9;
        }

        .action-item.additional label {
            font-style: italic;
            font-size: 12px;
        }

        .config-indicator {
            display: none; /* JS toggles this */
            align-items: center;
            gap: 4px;
            padding: 2px 4px 2px 8px;
            font-size: 10px;
            background: var(--accent-color);
            color: white;
            border-radius: 10px; /* Pill shape */
            white-space: nowrap;
            max-width: 150px;
            margin-left: auto; /* Push to right */
        }

        .config-name {
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100px;
        }

        .config-reset {
            cursor: pointer;
            width: 14px;
            height: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: rgba(0,0,0,0.1);
            transition: all 0.2s;
        }

        .config-reset:hover {
            background: rgba(0,0,0,0.3);
        }

        /* Validation Panel */
        .rule-item {
            padding: 6px 16px;
            font-size: 13px;
            line-height: 1.4;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }
        .rule-item:hover { background: var(--hover-bg); }
        .rule-item input[type="checkbox"] { margin: 0; margin-top: 2px; accent-color: var(--accent-color); }

        .severity-badge {
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: 600;
        }
        .severity-badge.error { background: #fee2e2; color: #dc2626; }
        .severity-badge.warning { background: #fef3c7; color: #d97706; }
        .severity-badge.info { background: #dbeafe; color: #2563eb; }

        [data-theme="dark"] .severity-badge.error { background: #991b1b; color: #fecaca; }
        [data-theme="dark"] .severity-badge.warning { background: #92400e; color: #fef3c7; }
        [data-theme="dark"] .severity-badge.info { background: #1e40af; color: #dbeafe; }

        /* Validation Toast */
        .validation-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 16px 24px;
            border-radius: 8px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-lg);
            z-index: 1000;
            animation: slideIn 0.3s ease;
        }
        .validation-toast.success { border-left: 4px solid var(--success-color); }
        .validation-toast.warning { border-left: 4px solid var(--warning-color); }
        .validation-toast.error { border-left: 4px solid var(--error-color); }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* Export Buttons */
        .export-buttons {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .export-btn {
            padding: 8px 12px;
            font-size: 13px;
            background: transparent;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            cursor: pointer;
            color: var(--text-primary);
            text-align: left;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .export-btn:hover:not(:disabled) {
            border-color: var(--accent-color);
            color: var(--accent-color);
            background: rgba(59, 130, 246, 0.05);
        }

        .export-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Main Content */
        .main-content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        /* Output Console */
        .output-panel {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-top: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: relative;
            height: 200px;
            min-height: 0;
            flex-shrink: 0;
            overflow: visible;
            transition: height 0.25s cubic-bezier(0.2, 0, 0.2, 1);
            box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
            z-index: 80;
        }

        .output-panel.collapsed {
            height: 24px !important;
            min-height: 24px !important;
        }

        /* Hide content when collapsed, but keep header visible */
        .output-panel.collapsed > .output-content,
        .output-panel.collapsed > .output-resizer {
            display: none;
        }

        .output-resizer {
            height: 6px;
            background: transparent;
            cursor: row-resize;
            position: absolute;
            top: -3px; 
            left: 0;
            right: 0;
            z-index: 100;
            transition: background 0.2s;
        }

        .output-resizer:hover, .output-resizer.resizing {
            background: var(--accent-color);
            opacity: 0.5;
        }

        .output-header {
            padding: 0 16px;
            height: 24px;
            box-sizing: border-box;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            user-select: none;
            background: rgba(0,0,0,0.01);
            cursor: pointer;
            transition: background 0.2s;
        }

        .output-header:hover {
            background: rgba(0,0,0,0.03);
        }

        [data-theme="dark"] .output-header:hover {
            background: rgba(255,255,255,0.03);
        }

        .output-header-chevron {
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            transition: transform 0.2s ease, color 0.2s ease;
        }

        .output-header:hover .output-header-chevron {
            color: var(--text-primary);
        }

        .output-panel.collapsed .output-header-chevron {
            transform: rotate(180deg);
        }

        .output-header-left {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .output-header h4 {
            margin: 0;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .output-header h4 i {
            width: 12px;
            height: 12px;
        }

        .output-content {
            flex: 1;
            overflow-y: auto;
            padding: 12px 16px;
            font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
            font-size: 12px;
            line-height: 1.6;
            color: var(--text-primary);
            background: rgba(255,255,255,0.4); 
        }
        
        [data-theme="dark"] .output-content {
            background: rgba(0,0,0,0.2);
        }

        .output-panel.collapsed .output-content {
            display: none;
        }

        .output-line {
            padding: 2px 0;
        }

        .output-line.success, .output-line.cleared { color: var(--success-color, #22c55e); }
        .output-line.warning, .output-line.dry_run { color: var(--warning-color, #f59e0b); }
        .output-line.error { color: var(--error-color, #ef4444); }
        .output-line.info { color: var(--accent-color); }

        /* Dirty State Banner */
        .dirty-banner {
            display: none;
            padding: 8px 16px;
            background: #fef3c7;
            color: #92400e;
            font-size: 12px;
            font-weight: 500;
        }

        [data-theme="dark"] .dirty-banner {
            background: #78350f;
            color: #fef3c7;
        }

        /* Welcome State */
        .welcome-state {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
        }

        .welcome-state h2 {
            font-size: 24px;
            margin-bottom: 8px;
        }

        .welcome-state p {
            font-size: 14px;
        }

        /* Wireframe container for API mode */
        .wireframe-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .wireframe-container header {
            position: relative;
        }

        .wireframe-container .main-content {
            flex: 1;
            overflow: hidden;
        }

        /* Hide wireframe footer in client UI */
        .pbir-wireframe footer {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Activity Bar -->
        <nav class="activity-bar">
            <div class="activity-icon active" id="nav-reports" onclick="switchActivityView('section-reports')" title="Reports">
                <i data-lucide="folder"></i>
            </div>
            <div class="activity-icon" id="nav-actions" onclick="switchActivityView('section-actions')" title="Actions">
                <i data-lucide="zap"></i>
            </div>
            <div class="activity-icon" id="nav-validate" onclick="switchActivityView('section-validate')" title="Validate">
                <i data-lucide="search"></i>
            </div>
            <div class="activity-icon" id="nav-export" onclick="switchActivityView('section-export')" title="Export">
                <i data-lucide="download"></i>
            </div>
            <div class="spacer"></div>
        </nav>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <!-- File Browser -->
            <div class="sidebar-section active" id="section-reports">
                <div class="sidebar-section-header">
                    <span class="section-title">REPORTS</span>
                </div>
                <div class="sidebar-section-content" id="section-reports-content">
                    <div class="breadcrumb" id="breadcrumb"></div>
                    <div id="file-list"></div>
                </div>
            </div>

            <!-- Actions -->
            <div class="sidebar-section actions-panel" id="section-actions">
                <div class="sidebar-section-header">
                    <span class="section-title">ACTIONS</span>
                    <span class="config-indicator" id="config-indicator"></span>
                </div>
                <div class="sidebar-section-content" id="section-actions-content">
                    <div class="action-buttons" style="border-bottom: 1px solid var(--border-color); padding-bottom: 8px; margin-bottom: 8px; position: sticky; top: 0; background: var(--sidebar-bg); z-index: 1;">
                        <button class="action-btn primary" onclick="runActions(false)" id="run-btn" disabled><i data-lucide="play" style="width: 14px; height: 14px;"></i> Run</button>
                        <button class="action-btn secondary" onclick="runActions(true)" id="dry-run-btn" disabled><i data-lucide="eye" style="width: 14px; height: 14px;"></i> Dry Run</button>
                    </div>
                    <div class="config-picker" style="padding: 4px 8px; margin-bottom: 8px; border-bottom: 1px solid var(--border-color);">
                        <input type="file" id="config-file-input" accept=".yaml,.yml" style="display: none;" onchange="loadCustomConfig(this)">
                        <button class="export-btn" onclick="document.getElementById('config-file-input').click()" style="width: 100%; justify-content: center; gap: 6px;">
                            <i data-lucide="file-json"></i> Load Sanitizer Config
                        </button>
                    </div>
                    <div id="actions-list"></div>
                </div>
            </div>

            <!-- Validate -->
            <div class="sidebar-section validation-panel" id="section-validate">
                <div class="sidebar-section-header">
                    <span class="section-title">VALIDATE</span>
                    <span class="config-indicator" id="rules-config-indicator"></span>
                </div>
                <div class="sidebar-section-content" id="section-validate-content">
                    <div class="action-buttons" style="border-bottom: 1px solid var(--border-color); padding: 8px 16px;">
                        <button class="action-btn primary" onclick="runCheck()" id="check-btn" disabled>
                            <i data-lucide="check"></i> Check
                        </button>
                    </div>
                    <div class="config-picker" style="padding: 4px 8px; margin-bottom: 8px; border-bottom: 1px solid var(--border-color);">
                        <input type="file" id="rules-config-file-input" accept=".yaml,.yml" style="display: none;" onchange="loadCustomRulesConfig(this)">
                        <button class="export-btn" onclick="document.getElementById('rules-config-file-input').click()" style="width: 100%; justify-content: center; gap: 6px;">
                            <i data-lucide="file-json"></i> Load Rules Config
                        </button>
                    </div>
                    <div class="action-item" style="border-bottom: 1px solid var(--border-color); margin-bottom: 8px; padding-bottom: 8px;">
                        <input type="checkbox" id="include-sanitizer-checks" checked>
                        <label for="include-sanitizer-checks" style="cursor: pointer;">Include sanitizer action checks</label>
                    </div>
                    <div id="rules-list"></div>
                </div>
            </div>

            <!-- Export -->
            <div class="sidebar-section" id="section-export">
                <div class="sidebar-section-header">
                    <span class="section-title">EXPORT</span>
                </div>
                <div class="sidebar-section-content" style="padding: 8px 12px;" id="section-export-content">
                    <div class="export-buttons">
                        <button class="export-btn" onclick="downloadCSV('attributes', true)" id="export-meta-btn" disabled
                            title="Export attributes for visuals currently visible in the wireframe (respects UI view and search & selection)">
                            <i data-lucide="file-spreadsheet"></i> Attributes CSV
                        </button>
                        <button class="export-btn" onclick="downloadCSV('visuals', true)" id="export-visuals-btn" disabled
                            title="Export visual metadata for visuals currently visible in the wireframe (respects UI view and search & selection)">
                            <i data-lucide="bar-chart-2"></i> Visuals CSV
                        </button>
                        <button class="export-btn" onclick="downloadWireframeHTML(true)" id="export-html-btn" disabled
                            title="Export wireframe as standalone HTML file (respects current filters)">
                            <i data-lucide="globe"></i> Wireframe HTML
                        </button>
                    </div>
                </div>
            </div>
            <div class="sidebar-resizer" onmousedown="initSidebarResize(event)"></div>
        </aside>

        <!-- Main Content -->
        <main class="main-content-wrapper">
            <div id="dirty-banner" class="dirty-banner"></div>

            <!-- Wireframe Container (populated dynamically) -->
            <div id="wireframe-container" class="wireframe-container">
                <div class="welcome-state" id="welcome-state">
                    <h2>PBIR-Utils</h2>
                    <p>Select a .Report folder from the sidebar to begin</p>
                </div>
            </div>

            <!-- Output Console -->
            <div class="output-panel collapsed" id="output-panel">
                <div class="output-resizer" id="output-resizer" onmousedown="initOutputResize(event)"></div>
                <div class="output-header" onclick="toggleOutputPanel()" title="Toggle Output Panel">
                    <div class="output-header-left" style="flex: 1;">
                        <h4 style="display: flex; align-items: center; gap: 6px;"><i data-lucide="clipboard-list"></i> Output</h4>
                    </div>
                    <span class="output-header-chevron">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </span>
                    <div style="flex: 1; display: flex; justify-content: flex-end;">
                        <button class="export-btn" onclick="clearOutput(); event.stopPropagation();" style="padding: 2px 8px; font-size: 11px;">Clear</button>
                    </div>
                </div>
                <div class="output-content" id="output-content"></div>
            </div>
        </main>
    </div>

    <script>
        // API Mode flag - client.js will set this
        var API_MODE = true;
        var fieldsIndex = {};
        var activePageId = null;
        var currentReportPath = null;
        var initialReportPath = {{ initial_report | tojson if initial_report else 'null' }};

        // Include wireframe.js functions
        {% include 'js/wireframe.js' %}
    </script>
    <script>
        {% include 'js/client.js' %}
    </script>
</body>
</html>
